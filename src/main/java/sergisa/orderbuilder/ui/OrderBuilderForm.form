<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="sergisa.orderbuilder.ui.OrderBuilderForm">
  <grid id="27dc6" binding="root" layout-manager="GridLayoutManager" row-count="4" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="10" left="10" bottom="10" right="10"/>
    <constraints>
      <xy x="20" y="20" width="555" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <splitpane id="b54a5">
        <constraints>
          <grid row="3" column="0" row-span="1" col-span="2" vsize-policy="3" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false">
            <preferred-size width="200" height="200"/>
          </grid>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <scrollpane id="c047">
            <constraints>
              <splitpane position="left"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <component id="4e704" class="javax.swing.JList" binding="printerListView" default-binding="true">
                <constraints/>
                <properties/>
              </component>
            </children>
          </scrollpane>
          <component id="2decc" class="javax.swing.JEditorPane" binding="orderEditorView">
            <constraints>
              <splitpane position="right"/>
            </constraints>
            <properties/>
          </component>
        </children>
      </splitpane>
      <component id="b9641" class="javax.swing.JButton" binding="refreshButton">
        <constraints>
          <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="4" fill="0" indent="1" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font name="Raleway Light"/>
          <text value="Сформировать"/>
        </properties>
      </component>
      <component id="54ea4" class="javax.swing.JLabel">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font name="Nunito ExtraBold" size="16"/>
          <text value="Формирование заявки"/>
        </properties>
      </component>
      <toolbar id="2944f">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="2" vsize-policy="0" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false">
            <preferred-size width="-1" height="20"/>
          </grid>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <component id="b903" class="javax.swing.JButton" binding="documentEditButton">
            <constraints/>
            <properties>
              <foreground color="-16756777"/>
              <text value="Редактировать шаблон документа"/>
            </properties>
          </component>
          <component id="68d00" class="javax.swing.JButton" binding="printerRepositoryEditButton">
            <constraints/>
            <properties>
              <foreground color="-16756777"/>
              <text value="Принтеры"/>
            </properties>
          </component>
        </children>
      </toolbar>
    </children>
  </grid>
</form>
